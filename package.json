{
  "name": "sekant-intercept-js",
  "version": "1.0.0",
  "description": "Context-Aware YARA Runtime Detection for JavaScript Environments",
  "main": "./dist/sekant-intercept.node.mjs",
  "exports": {
    ".": {
      "browser": "./dist/sekant-intercept.browser.mjs",
      "import": "./dist/sekant-intercept.node.mjs",
      "default": "./dist/sekant-intercept.node.mjs"
    }
  },
  "type": "module",
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "vitest"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "vitest": "vitest",
    "test": "npm run test:unit && npm run test:matching && npm run test:integration && npm run test:modules && npm run test:loops",
    "test:unit": "node tests/runAllUnitTests.mjs",
    "test:matching": "node tests/runAllMatchingTests.mjs",
    "test:integration": "node tests/runAllIntegrationTests.mjs",
    "test:modules": "node tests/runAllModuleTests.mjs",
    "test:loops": "node tests/runAllForLoopTests.mjs",
    "example:scanner": "node examples/exampleYaraScanner.mjs",
    "example:modules": "node examples/exampleMathModule.mjs && node examples/exampleHashModule.mjs && node examples/examplePEScanner.mjs && node examples/exampleELFScanner.mjs",
    "example:advanced": "node examples/exampleBooleanLiterals.mjs && node examples/exampleConditionsMatch.mjs && node examples/exampleDependentRules.mjs && node examples/exampleCompleteIntegration.mjs && node examples/exampleFilesizeOperator.mjs",
    "build": "node build.mjs",
    "benchmark": "node tests/benchmark.mjs",
    "compare": "sh tests/runDirectComparison.sh",
    "prepublishOnly": "npm run build" 
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rishi-sekantsec/sekant-intercept-js.git"
  },
  "keywords": [
    "javascript",
    "library",
    "yara",
    "intercept",
    "sekant",
    "embeddable",
    "content-inspection"
  ],
  "author": "Rishi Kant",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/rishi-sekantsec/sekant-intercept-js/issues"
  },
  "homepage": "https://github.com/rishi-sekantsec/sekant-intercept-js#readme",
  "dependencies": {
    "pe-library": "^2.0.1",
    "spark-md5": "^3.0.2"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "vitest": "^3.2.4"
  }
}
